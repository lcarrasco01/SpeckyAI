# Copy this file to .env.local at the repo root for local development.
# In Vercel, configure these in Project Settings → Environment Variables.

# OpenAI
OPENAI_API_KEY=your-openai-api-key
SERPER_API_KEY=your-serper-api-key

# Supabase (public, safe for client usage)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=you@example.com

# Team invites (JWT secret for invite tokens)
INVITE_JWT_SECRET=replace-with-long-random-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
